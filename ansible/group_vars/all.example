remote_dir: /mnt/storage
remote_user: <user>
authentik_pg_pass: "" // openssl rand -base64 36 | tr -d '\n'
authentik_secret_key: "" // openssl rand -base64 60 | tr -d '\n'
grafana_oauth_client_id: ""
grafana_oauth_client_secret: ""
n8n_encryption_key: "" # openssl rand -hex 32
n8n_basic_auth_user: "admin"
n8n_basic_auth_password: "" # set a strong password
n8n_basic_auth_active: "true"
n8n_host: "n8n.szynkowydom.pl"
n8n_protocol: "https"
n8n_webhook_url: "https://n8n.szynkowydom.pl/"
n8n_timezone: "Europe/Warsaw"
n8n_secure_cookie: "true"
backup_enabled: true
backup_dir: "{{ remote_dir }}/backups"
backup_retention_days: 30
backup_cron_hour: "3"
backup_cron_minute: "15"
node_exporter_textfile_dir: "/var/lib/node_exporter/textfile_collector"
backup_offsite_enabled: false
backup_restic_repository: "rclone:gdrive:homelab-backups"
backup_restic_password: ""
backup_rclone_config_path: "/root/.config/rclone/rclone.conf"
backup_restic_keep_daily: 14
backup_restic_keep_weekly: 8
backup_restic_keep_monthly: 12
samba_user: "<user>"
samba_password: "" # set this in all.yml before enabling Samba
samba_workgroup: "WORKGROUP"
samba_server_string: "Homelab NAS"
samba_shares:
  - name: "storage"
    path: "{{ remote_dir }}"
    read_only: "no"
    guest_ok: "no"
